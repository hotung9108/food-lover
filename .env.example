# ============================================================
# FoodLover - Environment Variables (EXAMPLE)
# ============================================================
# Copy file này thành .env và điền credentials thật:
#   cp .env.example .env
#
# Sau đó chạy: node generate-config.js
# ============================================================

# EmailJS Credentials (lấy từ https://www.emailjs.com/)
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Tùy chỉnh tên hiển thị
PARTNER_NAME=Bé Yêu
YOUR_NAME=Anh
